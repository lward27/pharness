# Pharness operator console: static Vite build served by unprivileged nginx
# with same-origin /api and /health proxying to the pharness-api service.
FROM node:22-bookworm-slim AS builder
WORKDIR /build
COPY ui/package.json ui/package-lock.json ./
RUN npm ci --no-audit --no-fund
COPY ui/ .
RUN npm run build

FROM nginxinc/nginx-unprivileged:1.27-alpine
COPY deploy/docker/nginx-ui.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /build/dist /usr/share/nginx/html
